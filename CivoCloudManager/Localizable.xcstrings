    "API key not configured.\nOpen setup to add your Civo API key.": {
      "localizations": {
        "de": { "stringUnit": { "state": "translated", "value": "API-Schlüssel nicht konfiguriert.\nÖffne die Einrichtung, um deinen Civo-API-Schlüssel hinzuzufügen." } },
        "en": { "stringUnit": { "state": "translated", "value": "API key not configured.\nOpen setup to add your Civo API key." } },
