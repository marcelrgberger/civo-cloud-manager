    "Manage your Civo Cloud infrastructure directly from your Mac.\n\nFirewalls, Kubernetes, databases, and more — all in one app.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Manage your Civo Cloud infrastructure directly from your Mac.\n\nFirewalls, Kubernetes, databases, and more — all in one app."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verwalten Sie Ihre Civo Cloud Infrastruktur direkt von Ihrem Mac.\n\nFirewalls, Kubernetes, Datenbanken und mehr — alles in einer App."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Gestiona tu infraestructura Civo Cloud directamente desde tu Mac.\n\nFirewalls, Kubernetes, bases de datos y más — todo en una app."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gérez votre infrastructure Civo Cloud directement depuis votre Mac.\n\nPare-feu, Kubernetes, bases de données et plus — tout en une app."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Gestisci la tua infrastruttura Civo Cloud direttamente dal tuo Mac.\n\nFirewall, Kubernetes, database e altro — tutto in un’app."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Beheer uw Civo Cloud infrastructuur rechtstreeks vanaf uw Mac.\n\nFirewalls, Kubernetes, databases en meer — alles in één app."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zarządzaj infrastrukturą Civo Cloud bezpośrednio z Maca.\n\nFirewalle, Kubernetes, bazy danych i więcej — wszystko w jednej aplikacji."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Gerencie sua infraestrutura Civo Cloud diretamente do seu Mac.\n\nFirewalls, Kubernetes, bases de dados e mais — tudo numa app."
          }
        }
      }
    },
    "Managing %lld firewall%@. You can change settings anytime from the menu bar.": {
      "comment": "A message that congratulates the user on successfully configuring their Civo Cloud Manager setup, highlighting the number of firewalls they have selected.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "en": {
